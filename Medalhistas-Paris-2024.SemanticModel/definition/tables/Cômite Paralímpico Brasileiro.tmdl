table 'Cômite Paralímpico Brasileiro'
	lineageTag: ec3e9c9b-3fec-4cd0-a669-e209569b71a3

	measure 'Altura do atleta' =
			
			IF(
			    HASONEVALUE('Cômite Paralímpico Brasileiro'[nome]),
			    SELECTEDVALUE('Cômite Paralímpico Brasileiro'[altura]),
			    " "
			)
		lineageTag: 905704e5-0f5b-493e-8bff-1665359c4051

	measure 'Biografia do atleta' =
			
